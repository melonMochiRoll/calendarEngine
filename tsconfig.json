{
  "compilerOptions": {
    "module": "esnext",
    "target": "es6",
    "outDir": "./dist",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "bundler",
    "jsx": "react",
    "strict": true,
    "allowJs": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "esModuleInterop" : true,
    "allowSyntheticDefaultImports" : true,
    "paths": {
      "Src/*": ["./src/*"],
      "Api/*": ["./src/api/*"],
      "Components/*": ["./src/components/*"],
      "Constants/*": ["./src/constants/*"],
      "Containers/*": ["./src/containers/*"],
      "Features/*": ["./src/features/*"],
      "Hooks/*": ["./src/hooks/*"],
      "Layouts/*": ["./src/layouts/*"],
      "Lib/*": ["./src/lib/*"],
      "Pages/*": ["./src/pages/*"],
      "Routes/*": ["./src/routes/*"],
      "Styles/*": ["./src/styles/*"],
      "Typings/*": ["./src/typings/*"],
    },
  }
}